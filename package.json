{
  "name": "api-node-ts",
  "version": "1.0.0",
  "description": "Um projeto com foco em desenvolvimento backend, a partir de tecnologias como node, express, typescript e diversas outras stacks importantes",
  "homepage": "https://github.com/Alisson014/api-node-ts#readme",
  "bugs": {
    "url": "https://github.com/Alisson014/api-node-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alisson014/api-node-ts.git"
  },
  "license": "MIT",
  "author": "José Alisson",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "start": "npx tsx ./src/app.ts",
    "knex:migrate": "npx tsx ./node_modules/knex/bin/cli.js migrate:latest",
    "knex:rollback-all": "npx tsx ./node_modules/knex/bin/cli.js migrate:rollback --all",
    "knex:seed": "npx tsx ./node_modules/knex/bin/cli.js seed:run",
    "knex:rollback": "npx tsx ./node_modules/knex/bin/cli.js migrate:rollback"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "sqlite3": "^6.0.1",
    "knex": "^3.1.0",
    "ts-node": "^10.9.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
